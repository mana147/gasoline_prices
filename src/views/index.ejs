<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MPC - service</title>
    <link rel="stylesheet" href="/css/index.css">
    <style>
        .back-to-menu {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-size: 0.875rem;
            font-weight: 600;
            color: var(--text-muted);
            text-decoration: none;
            padding: 8px 14px;
            border-radius: 999px;
            border: 1px solid var(--border);
            background: rgba(255,255,255,0.03);
            transition: color 0.2s, border-color 0.2s, background 0.2s;
            white-space: nowrap;
        }
        .back-to-menu:hover {
            color: var(--text);
            border-color: var(--border-strong);
            background: rgba(255,255,255,0.06);
        }
    </style>
</head>

<body>
    <div class="container">
        <header class="page-header">
            <a href="/menu" class="back-to-menu">← Menu</a>
            <div class="brand">
                <div class="icon"><img src="/logo.png" alt="logo"></div>
                <div class="brand-content">
                    <h1 class="brand-title">MPC Fuel Service</h1>
                </div>
            </div>
            <p class="page-description">Chọn ngày để lấy dữ liệu giá dầu chính xác và tính toán phụ thu theo bảng hiện hành.</p>
        </header>

        <section class="card">
            <div class="form-group">
                <div>
                    <label for="dateInput">📋 Chọn ngày</label>
                    <input type="date" id="dateInput">
                </div>
                <button class="btn" id="fetchBtn" onclick="fetchFuelPrice()">
                    Tra cứu giá xăng dầu
                </button>
            </div>
        </section>

        <div id="loadingSection" class="card hidden">
            <div class="loading">
                <div class="spinner"></div>
                <p>Đang tải dữ liệu...</p>
            </div>
        </div>

        <div id="errorSection" class="card hidden">
            <div class="error" id="errorMessage"></div>
        </div>

        <div id="resultSection" class="card hidden">
            <div class="result-header">
                <h2>Kết quả tra cứu: </h2>
                <span class="price-tag" id="priceTag"></span>
            </div>

            <div class="info-grid">
                <div hidden class="info-item">
                    <label>Ngày</label>
                    <span id="resultDate">-</span>
                </div>
                <div class="info-item">
                    <label>Thương hiệu</label>
                    <span id="resultBrand">-</span>
                </div>
                <div class="info-item">
                    <label>Loại nhiên liệu</label>
                    <span id="resultTitle">-</span>
                </div>
                <div class="info-item">
                    <label>Giá vùng 1</label>
                    <span id="resultZone1">-</span>
                </div>
                <div class="info-item">
                    <label>Giá vùng 2</label>
                    <span id="resultZone2">-</span>
                </div>
            </div>

            <div class="surcharge-section">
                <h3>📦 Phụ thu Container Hàng</h3>
                <div class="surcharge-grid">
                    <div class="surcharge-item hang">
                        <div class="size">20' (AMT_F20)</div>
                        <div class="value" id="hang20">-</div>
                    </div>
                    <div class="surcharge-item hang">
                        <div class="size">40' (AMT_F40)</div>
                        <div class="value" id="hang40">-</div>
                    </div>
                    <div class="surcharge-item hang">
                        <div class="size">45' (AMT_F45)</div>
                        <div class="value" id="hang45">-</div>
                    </div>
                </div>
            </div>

            <div class="surcharge-section" style="margin-top: 25px;">
                <h3>📦 Phụ thu Container Rỗng</h3>
                <div class="surcharge-grid">
                    <div class="surcharge-item rong">
                        <div class="size">20' (AMT_E20)</div>
                        <div class="value" id="rong20">-</div>
                    </div>
                    <div class="surcharge-item rong">
                        <div class="size">40' (AMT_E40)</div>
                        <div class="value" id="rong40">-</div>
                    </div>
                    <div class="surcharge-item rong">
                        <div class="size">45' (AMT_E45)</div>
                        <div class="value" id="rong45">-</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- TRF_STD Section - Biểu cước hiện tại từ SQL Server -->
        <div class="card trf-std-section">
            <div class="form-group">
                <h4>🏷️ Biểu Cước phụ thu hiện tại ( PLTOS : TRF_STD)</h4>
                <button class="refresh-btn" id="refreshTrfBtn" onclick="loadTrfStdData()">
                    🔄 Làm mới
                </button>
            </div>

            <div id="trfStdLoading" class="trf-std-loading hidden">
                <div class="spinner"></div>
                <p>Đang tải dữ liệu...</p>
            </div>

            <div id="trfStdError" class="trf-std-error hidden"></div>

            <div id="trfStdContent" class="trf-std-grid">
                <!-- Container Hàng -->
                <div class="trf-std-card hang">
                    <div class="trf-std-card-header">📦 Container Hàng (HH + NH)</div>
                    <div class="trf-std-card-body">
                        <div class="trf-std-row">
                            <span class="label">20' (AMT_F20)</span>
                            <span class="value" id="trfHang20">-</span>
                        </div>
                        <div class="trf-std-row">
                            <span class="label">40' (AMT_F40)</span>
                            <span class="value" id="trfHang40">-</span>
                        </div>
                        <div class="trf-std-row">
                            <span class="label">45' (AMT_F45)</span>
                            <span class="value" id="trfHang45">-</span>
                        </div>
                    </div>
                </div>

                <!-- Container Rỗng -->
                <div class="trf-std-card rong">
                    <div class="trf-std-card-header">📦 Container Rỗng (NR + HR)</div>
                    <div class="trf-std-card-body">
                        <div class="trf-std-row">
                            <span class="label">20' (AMT_E20)</span>
                            <span class="value" id="trfRong20">-</span>
                        </div>
                        <div class="trf-std-row">
                            <span class="label">40' (AMT_E40)</span>
                            <span class="value" id="trfRong40">-</span>
                        </div>
                        <div class="trf-std-row">
                            <span class="label">45' (AMT_E45)</span>
                            <span class="value" id="trfRong45">-</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Update TRF_STD Section -->
        <div class="card update-trf-section">
            <div class="form-group">
                <h4>✏️ Cập nhật Biểu Cước phụ thu (TRF_STD)</h4>
                <button class="copy-from-result-btn" onclick="copyFromResult()" title="Sao chép từ kết quả tra cứu">
                    📋 Copy từ kết quả tra cứu
                </button>
            </div>

            <div class="update-form-grid">
                <!-- Form Container Hàng -->
                <div class="update-form-card hang">
                    <div class="update-form-header">📦 Container Hàng (NH + HH)</div>
                    <div class="update-form-body">
                        <div class="update-input-group">
                            <label>20' (AMT_F20)</label>
                            <input type="number" id="updateHang20" placeholder="Nhập giá trị...">
                        </div>
                        <div class="update-input-group">
                            <label>40' (AMT_F40)</label>
                            <input type="number" id="updateHang40" placeholder="Nhập giá trị...">
                        </div>
                        <div class="update-input-group">
                            <label>45' (AMT_F45)</label>
                            <input type="number" id="updateHang45" placeholder="Nhập giá trị...">
                        </div>
                        <div class="update-btn-group">
                            <button class="update-btn secondary" onclick="clearHangForm()">Xóa</button>
                            <button class="update-btn primary" id="updateHangBtn" onclick="updateTrfStdHang()">Cập nhật NH + HH</button>
                        </div>
                        <div id="hangUpdateMessage" class="update-message hidden"></div>
                    </div>
                </div>

                <!-- Form Container Rỗng -->
                <div class="update-form-card rong">
                    <div class="update-form-header">📦 Container Rỗng (NR + HR)</div>
                    <div class="update-form-body">
                        <div class="update-input-group">
                            <label>20' (AMT_E20)</label>
                            <input type="number" id="updateRong20" placeholder="Nhập giá trị...">
                        </div>
                        <div class="update-input-group">
                            <label>40' (AMT_E40)</label>
                            <input type="number" id="updateRong40" placeholder="Nhập giá trị...">
                        </div>
                        <div class="update-input-group">
                            <label>45' (AMT_E45)</label>
                            <input type="number" id="updateRong45" placeholder="Nhập giá trị...">
                        </div>
                        <div class="update-btn-group">
                            <button class="update-btn secondary" onclick="clearRongForm()">Xóa</button>
                            <button class="update-btn primary rong" id="updateRongBtn" onclick="updateTrfStdRong()">Cập nhật NR + HR</button>
                        </div>
                        <div id="rongUpdateMessage" class="update-message hidden"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Bảng Phụ Thu Section -->
        <div class="card surcharge-table-section">
            <div class="form-group" >
                <h4>📋 Bảng phụ thu theo giá dầu</h4>
            </div>
            <div id="surchargeTableContainer">
                <table class="surcharge-table">
                    <thead>
                        <tr>
                            <th rowspan="2">Giá DO (VNĐ)</th>
                            <th colspan="3" class="table-header-group hang">Container Hàng</th>
                            <th colspan="3" class="table-header-group rong">Container Rỗng</th>
                        </tr>
                        <tr>
                            <th>20'</th>
                            <th>40'</th>
                            <th>45'</th>
                            <th>20'</th>
                            <th>40'</th>
                            <th>45'</th>
                        </tr>
                    </thead>
                    <tbody id="surchargeTableBody">
                        <!-- Data will be loaded here -->
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <script>

        let API_URL = '/api/get_fuel_price';
        let API_BASE = '/api';

        API_URL = window.API_URL || API_URL;
        API_BASE = window.API_BASE || API_BASE;

        // Check authentication on page load
        document.addEventListener('DOMContentLoaded', async function () {
            const token = localStorage.getItem('token');

            if (!token) {
                window.location.href = '/login';
                return;
            }

            try {
                const response = await fetch(`${API_BASE}/me`, { headers: { 'Authorization': `Bearer ${token}` } });

                if (!response.ok) {
                    localStorage.removeItem('token');
                    localStorage.removeItem('user');
                    window.location.href = '/login';
                    return;
                }

                const today = new Date().toISOString().split('T')[0];
                document.getElementById('dateInput').value = today;
                await loadSurchargeTable();

            } catch (error) {
                console.error('Auth check failed:', error);
                window.location.href = '/login';
            }
        });

        function formatCurrency(value) {
            if (value === null || value === undefined) return '-';
            return new Intl.NumberFormat('vi-VN').format(value) + ' đ';
        }

        function showSection(sectionId) {
            ['loadingSection', 'errorSection', 'resultSection'].forEach(id => {
                document.getElementById(id).classList.add('hidden');
            });
            if (sectionId) {
                document.getElementById(sectionId).classList.remove('hidden');
            }
        }

        async function fetchFuelPrice() {
            const dateInput = document.getElementById('dateInput');
            const fetchBtn = document.getElementById('fetchBtn');
            const date = dateInput.value;

            if (!date) {
                alert('Vui lòng chọn ngày!');
                return;
            }

            showSection('loadingSection');
            fetchBtn.disabled = true;

            try {
                const response = await fetch(`${API_URL}?date=${date}`, { headers: { 'Authorization': `Bearer ${localStorage.getItem('token')}` } });

                if (!response.ok) throw new Error(`HTTP error! status: ${response.status}`);

                const data = await response.json();

                document.getElementById('resultDate').textContent = data.date || '-';
                document.getElementById('resultBrand').textContent = data.brand || '-';
                document.getElementById('resultTitle').textContent = data.title || '-';
                document.getElementById('resultZone1').textContent = formatCurrency(data.zone1_price);
                document.getElementById('resultZone2').textContent = formatCurrency(data.zone2_price);
                document.getElementById('priceTag').textContent = formatCurrency(data.zone1_price);

                document.getElementById('hang20').textContent = formatCurrency(data.hang_20);
                document.getElementById('hang40').textContent = formatCurrency(data.hang_40);
                document.getElementById('hang45').textContent = formatCurrency(data.hang_45);

                document.getElementById('rong20').textContent = formatCurrency(data.rong_20);
                document.getElementById('rong40').textContent = formatCurrency(data.rong_40);
                document.getElementById('rong45').textContent = formatCurrency(data.rong_45);

                showSection('resultSection');

            } catch (error) {
                console.error('Error fetching fuel price:', error);
                document.getElementById('errorMessage').textContent =
                    `Lỗi: ${error.message}. Vui lòng kiểm tra kết nối server.`;
                showSection('errorSection');
            } finally {
                fetchBtn.disabled = false;
            }
        }

        document.getElementById('dateInput').addEventListener('keypress', function (e) {
            if (e.key === 'Enter') {
                fetchFuelPrice();
            }
        });

        // ============================================================================
        // Surcharge Table Functions
        // ============================================================================

        let surchargeTableLoaded = false;

        function toggleSurchargeTable() {
            const container = document.getElementById('surchargeTableContainer');
            const btn = document.getElementById('toggleTableBtn');

            if (container.classList.contains('hidden')) {
                container.classList.remove('hidden');
                btn.textContent = 'Ẩn bảng phụ thu';

                if (!surchargeTableLoaded) {
                    loadSurchargeTable();
                }
            } else {
                container.classList.add('hidden');
                btn.textContent = 'Hiện bảng phụ thu';
            }
        }

        async function loadSurchargeTable() {
            try {
                const response = await fetch(`${API_BASE}/get_surcharge_table`);

                if (!response.ok) {
                    throw new Error('Failed to load surcharge table');
                }

                const data = await response.json();
                renderSurchargeTable(data);
                surchargeTableLoaded = true;

            } catch (error) {
                console.error('Error loading surcharge table:', error);
                document.getElementById('surchargeTableBody').innerHTML = `
                    <tr>
                        <td colspan="7" style="color: red; text-align: center;">
                            Lỗi tải dữ liệu bảng phụ thu
                        </td>
                    </tr>
                `;
            }
        }

        function renderSurchargeTable(data) {
            const tbody = document.getElementById('surchargeTableBody');
            let html = '';

            data.forEach(item => {
                const priceRange = item.min === 0
                    ? `0 - ${formatNumber(item.max)}`
                    : `${formatNumber(item.min)} - ${formatNumber(item.max)}`;

                html += `
                    <tr>
                        <td class="price-range">${priceRange}</td>
                        <td class="hang-col">${formatNumber(item.surcharge.hang_20)}</td>
                        <td class="hang-col">${formatNumber(item.surcharge.hang_40)}</td>
                        <td class="hang-col">${formatNumber(item.surcharge.hang_45)}</td>
                        <td class="rong-col">${formatNumber(item.surcharge.rong_20)}</td>
                        <td class="rong-col">${formatNumber(item.surcharge.rong_40)}</td>
                        <td class="rong-col">${formatNumber(item.surcharge.rong_45)}</td>
                    </tr>
                `;
            });

            tbody.innerHTML = html;
        }

        function formatNumber(value) {
            if (value === 0) return '0';
            return new Intl.NumberFormat('vi-VN').format(value);
        }

        // ============================================================================
        // TRF_STD Functions
        // ============================================================================

        document.addEventListener('DOMContentLoaded', function() {
            setTimeout(() => {
                if (localStorage.getItem('token')) {
                    loadTrfStdData();
                }
            }, 500);
        });

        async function loadTrfStdData() {
            const loadingEl = document.getElementById('trfStdLoading');
            const errorEl = document.getElementById('trfStdError');
            const contentEl = document.getElementById('trfStdContent');
            const refreshBtn = document.getElementById('refreshTrfBtn');

            loadingEl.classList.remove('hidden');
            errorEl.classList.add('hidden');
            contentEl.style.opacity = '0.5';
            refreshBtn.disabled = true;

            try {
                const response = await fetch(`${API_BASE}/get_trf_std`, {
                    headers: { 'Authorization': `Bearer ${localStorage.getItem('token')}` }
                });

                if (!response.ok) {
                    throw new Error('Failed to load TRF_STD data');
                }

                const data = await response.json();
                renderTrfStdData(data);

            } catch (error) {
                console.error('Error loading TRF_STD:', error);
                errorEl.textContent = 'Lỗi tải dữ liệu biểu cước. Vui lòng thử lại!';
                errorEl.classList.remove('hidden');
            } finally {
                loadingEl.classList.add('hidden');
                contentEl.style.opacity = '1';
                refreshBtn.disabled = false;
            }
        }

        function renderTrfStdData(data) {
            const hangData = data.HH || data.NH || {};
            document.getElementById('trfHang20').textContent = formatCurrency(hangData.hang_20 || 0);
            document.getElementById('trfHang40').textContent = formatCurrency(hangData.hang_40 || 0);
            document.getElementById('trfHang45').textContent = formatCurrency(hangData.hang_45 || 0);

            const rongData = data.NR || data.HR || {};
            document.getElementById('trfRong20').textContent = formatCurrency(rongData.rong_20 || 0);
            document.getElementById('trfRong40').textContent = formatCurrency(rongData.rong_40 || 0);
            document.getElementById('trfRong45').textContent = formatCurrency(rongData.rong_45 || 0);
        }

        // ============================================================================
        // Update TRF_STD Functions
        // ============================================================================

        function copyFromResult() {
            const parseValue = (str) => {
                if (!str || str === '-') return '';
                return parseInt(str.replace(/[^0-9]/g, '')) || '';
            };

            document.getElementById('updateHang20').value = parseValue(document.getElementById('hang20').textContent);
            document.getElementById('updateHang40').value = parseValue(document.getElementById('hang40').textContent);
            document.getElementById('updateHang45').value = parseValue(document.getElementById('hang45').textContent);
            document.getElementById('updateRong20').value = parseValue(document.getElementById('rong20').textContent);
            document.getElementById('updateRong40').value = parseValue(document.getElementById('rong40').textContent);
            document.getElementById('updateRong45').value = parseValue(document.getElementById('rong45').textContent);

            alert('Đã sao chép giá trị từ kết quả tra cứu!');
        }

        function clearHangForm() {
            document.getElementById('updateHang20').value = '';
            document.getElementById('updateHang40').value = '';
            document.getElementById('updateHang45').value = '';
            hideMessage('hangUpdateMessage');
        }

        function clearRongForm() {
            document.getElementById('updateRong20').value = '';
            document.getElementById('updateRong40').value = '';
            document.getElementById('updateRong45').value = '';
            hideMessage('rongUpdateMessage');
        }

        function showMessage(elementId, message, isSuccess) {
            const el = document.getElementById(elementId);
            el.textContent = message;
            el.className = `update-message ${isSuccess ? 'success' : 'error'}`;
            el.classList.remove('hidden');
            setTimeout(() => hideMessage(elementId), 5000);
        }

        function hideMessage(elementId) {
            document.getElementById(elementId).classList.add('hidden');
        }

        async function updateTrfStdHang() {
            const hang20 = document.getElementById('updateHang20').value;
            const hang40 = document.getElementById('updateHang40').value;
            const hang45 = document.getElementById('updateHang45').value;

            if (!hang20 || !hang40 || !hang45) {
                showMessage('hangUpdateMessage', 'Vui lòng nhập đầy đủ giá trị!', false);
                return;
            }

            const btn = document.getElementById('updateHangBtn');
            btn.disabled = true;
            btn.textContent = 'Đang cập nhật...';

            try {
                for (const trf_code of ['NH', 'HH']) {
                    const res = await fetch(`${API_BASE}/update_trf_std`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${localStorage.getItem('token')}` },
                        body: JSON.stringify({ trf_code, hang_20: parseFloat(hang20), hang_40: parseFloat(hang40), hang_45: parseFloat(hang45) })
                    });
                    if (!res.ok) {
                        const errData = await res.json();
                        throw new Error(errData.error || `Failed to update ${trf_code}`);
                    }
                }

                showMessage('hangUpdateMessage', '✓ Cập nhật NH + HH thành công!', true);
                loadTrfStdData();

            } catch (error) {
                console.error('Error updating Hang:', error);
                showMessage('hangUpdateMessage', `✗ Lỗi: ${error.message}`, false);
            } finally {
                btn.disabled = false;
                btn.textContent = 'Cập nhật NH + HH';
            }
        }

        async function updateTrfStdRong() {
            const rong20 = document.getElementById('updateRong20').value;
            const rong40 = document.getElementById('updateRong40').value;
            const rong45 = document.getElementById('updateRong45').value;

            if (!rong20 || !rong40 || !rong45) {
                showMessage('rongUpdateMessage', 'Vui lòng nhập đầy đủ giá trị!', false);
                return;
            }

            const btn = document.getElementById('updateRongBtn');
            btn.disabled = true;
            btn.textContent = 'Đang cập nhật...';

            try {
                for (const trf_code of ['NR', 'HR']) {
                    const res = await fetch(`${API_BASE}/update_trf_std`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${localStorage.getItem('token')}` },
                        body: JSON.stringify({ trf_code, rong_20: parseFloat(rong20), rong_40: parseFloat(rong40), rong_45: parseFloat(rong45) })
                    });
                    if (!res.ok) {
                        const errData = await res.json();
                        throw new Error(errData.error || `Failed to update ${trf_code}`);
                    }
                }

                showMessage('rongUpdateMessage', '✓ Cập nhật NR + HR thành công!', true);
                loadTrfStdData();

            } catch (error) {
                console.error('Error updating Rong:', error);
                showMessage('rongUpdateMessage', `✗ Lỗi: ${error.message}`, false);
            } finally {
                btn.disabled = false;
                btn.textContent = 'Cập nhật NR + HR';
            }
        }

    </script>
</body>

</html>
